{
  "info": {
    "name": "MCI API",
    "_postman_id": "mci-api-collection",
    "description": "Coleção completa da MCI API (NestJS + Prisma + PostgreSQL). Rotas protegidas exigem JWT Bearer Token no header Authorization.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token obtido via POST /auth/login"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@email.com\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"] }
          }
        },
        {
          "name": "Me (usuário logado)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Mudar Ano",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ano\": 2026\n}"
            },
            "url": { "raw": "{{base_url}}/auth/ano", "host": ["{{base_url}}"], "path": ["auth", "ano"] }
          }
        },
        {
          "name": "Esqueci Minha Senha",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao.silva@mci.com\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/esqueci-senha", "host": ["{{base_url}}"], "path": ["auth", "esqueci-senha"] },
            "description": "Envia um código numérico de 6 dígitos (válido por 15 min) para o e-mail informado. A resposta é sempre a mesma por segurança, independente de o e-mail existir."
          }
        },
        {
          "name": "Redefinir Senha (com código do e-mail)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao.silva@mci.com\",\n  \"codigo\": \"482931\",\n  \"nova_senha\": \"novaSenha@2026\",\n  \"confirmacao_senha\": \"novaSenha@2026\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/redefinir-senha", "host": ["{{base_url}}"], "path": ["auth", "redefinir-senha"] },
            "description": "Valida o código de 6 dígitos recebido por e-mail e define a nova senha. O código expira em 15 minutos e só pode ser usado uma vez."
          }
        },
        {
          "name": "Alterar Senha (usuário logado)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senha_atual\": \"senhaAtual123\",\n  \"nova_senha\": \"novaSenha@2026\",\n  \"confirmacao_senha\": \"novaSenha@2026\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/alterar-senha", "host": ["{{base_url}}"], "path": ["auth", "alterar-senha"] },
            "description": "Rota protegida (JWT). O usuário logado informa a senha atual para confirmação e escolhe a nova senha."
          }
        }
      ]
    },
    {
      "name": "Usuários",
      "item": [
        {
          "name": "Listar Usuários",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/usuarios", "host": ["{{base_url}}"], "path": ["usuarios"] }
