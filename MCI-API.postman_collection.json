          }
        },
        {
          "name": "Buscar Usuário por ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/usuarios/:id",
              "host": ["{{base_url}}"],
              "path": ["usuarios", ":id"],
              "variable": [{ "key": "id", "value": "UUID-AQUI" }]
            }
          }
        },
        {
          "name": "Criar Usuário",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João Silva\",\n  \"email\": \"joao@email.com\",\n  \"senha\": \"senha123\",\n  \"confirmacao_senha\": \"senha123\",\n  \"id_role\": 1,\n  \"id_nivel\": 1,\n  \"relacao\": \"UUID-OPCIONAL\"\n}"
            },
            "url": { "raw": "{{base_url}}/usuarios", "host": ["{{base_url}}"], "path": ["usuarios"] }
          }
        },
        {
          "name": "Atualizar Usuário",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João Silva Atualizado\",\n  \"email\": \"joao.atualizado@email.com\",\n  \"id_role\": 1,\n  \"id_nivel\": 1,\n  \"relacao\": \"UUID-OPCIONAL\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/usuarios/:id",
              "host": ["{{base_url}}"],
              "path": ["usuarios", ":id"],
              "variable": [{ "key": "id", "value": "UUID-AQUI" }]
            },
            "description": "Atualiza dados do usuário (nome, e-mail, role, nível, relação). Senha NÃO é alterada aqui — use PATCH /auth/alterar-senha ou o fluxo de esqueci-senha."
          }
        },
        {
          "name": "Remover Usuário",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/usuarios/:id/remover",
              "host": ["{{base_url}}"],
              "path": ["usuarios", ":id", "remover"],
              "variable": [{ "key": "id", "value": "UUID-AQUI" }]
            }
          }
        },
        {
          "name": "Filtrar Usuários",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João\",\n  \"email\": \"joao@email.com\",\n  \"id_role\": 1,\n  \"id_nivel\": 1\n}"
            },
            "url": { "raw": "{{base_url}}/usuarios/filtrar", "host": ["{{base_url}}"], "path": ["usuarios", "filtrar"] }
          }
        }
      ]
